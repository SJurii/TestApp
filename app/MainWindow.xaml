<Window x:Class="app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:app.ViewModels"
        mc:Ignorable="d"
        Title="Мониторинг Валют" Height="650" Width="850"
        Background="#F5F6F7" FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="AddButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="RefreshButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#4B5563"/>
        </Style>

        <Style x:Key="DeleteRowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FEE2E2"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FECACA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="20,15">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="➕ Добавить валюту" 
                            Command="{Binding OpenAddMoneyCommand}" 
                            Style="{StaticResource AddButtonStyle}"/>

                    <Button Content="📁 Локальный кэш" 
                            Command="{Binding RefreshDataCommand}" 
                            Style="{StaticResource GhostButtonStyle}"/>
                </StackPanel>

                <Button Content="🌐 Обновить из сети"
                        Command="{Binding UpdateDataCommand}"
                        HorizontalAlignment="Right"
                        Style="{StaticResource RefreshButtonStyle}"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="20" Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid>
                <ListView ItemsSource="{Binding MoneyList}" 
                          BorderThickness="0" 
                          Background="Transparent"
                          Margin="5">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="80">
                                <GridViewColumn.Header>
                                    <TextBlock Text="Код" FontWeight="Bold" Margin="5,0"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.DisplayMemberBinding>
                                    <Binding Path="CharCode"/>
                                </GridViewColumn.DisplayMemberBinding>
                            </GridViewColumn>

                            <GridViewColumn Width="280">
                                <GridViewColumn.Header>
                                    <TextBlock Text="Название" FontWeight="Bold" Margin="5,0"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.DisplayMemberBinding>
                                    <Binding Path="Name"/>
                                </GridViewColumn.DisplayMemberBinding>
                            </GridViewColumn>

                            <GridViewColumn Width="110">
                                <GridViewColumn.Header>
                                    <TextBlock Text="Курс (₽)" FontWeight="Bold" Margin="5,0"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.DisplayMemberBinding>
                                    <Binding Path="Value" StringFormat="{}{0:F4}"/>
                                </GridViewColumn.DisplayMemberBinding>
                            </GridViewColumn>

                            <GridViewColumn Width="90">
                                <GridViewColumn.Header>
                                    <TextBlock Text="Номинал" FontWeight="Bold" Margin="5,0"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.DisplayMemberBinding>
                                    <Binding Path="Nominal"/>
                                </GridViewColumn.DisplayMemberBinding>
                            </GridViewColumn>

                            <GridViewColumn Width="100">
                                <GridViewColumn.Header>
                                    <TextBlock Text="Действие" FontWeight="Bold" Margin="5,0"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Удалить" 
                                                Style="{StaticResource DeleteRowButtonStyle}"
                                                Command="{Binding DataContext.DeleteMoneyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="20,12">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,8,0"/>
                    <TextBlock Text="Система готова" Foreground="#6B7280" FontSize="11"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Последнее обновление:" Foreground="#9CA3AF" FontSize="11" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding LastSessionText}" 
                       FontWeight="Bold" 
                       Foreground="#374151" 
                       FontSize="11"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>