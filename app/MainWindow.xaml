<Window x:Class="app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:app.ViewModels"
        mc:Ignorable="d"
        Title="Курсы Валют" Height="600" Width="800">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <StackPanel>
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Vertical" Grid.Column="0">
                <Button Content="Добавить валюту" 
                    Command="{Binding OpenAddMoneyCommand}" 
                    HorizontalAlignment="Left" 
                    Width="150"
                    Margin="10"/>
                <Button Content="Загрузить данные" 
                    Command="{Binding RefreshDataCommand}" 
                    HorizontalAlignment="Left" 
                    Width="150"
                    Margin="10"/>
            </StackPanel>
            <Button Content="Обновить данные"
                Command="{Binding UpdateDataCommand}"
                HorizontalAlignment="Right"
                Grid.Row="1"
                Width="150"
                Margin="10"/>
            <TextBlock Text="{Binding LastSessionText}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="10px"
                       Foreground="Gray"
                       FontSize="12"/>
        </Grid>

        <ListView ItemsSource="{Binding MoneyList}" Margin="10" Height="450">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Код" DisplayMemberBinding="{Binding CharCode}" Width="50"/>
                    <GridViewColumn Header="Название Валюты" DisplayMemberBinding="{Binding Name}" Width="250"/>
                    <GridViewColumn Header="Курс" DisplayMemberBinding="{Binding Value}" Width="100"/>
                    <GridViewColumn Header="Номинал" DisplayMemberBinding="{Binding Nominal}" Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>
    </StackPanel>
</Window>